{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "dangerouslyDisableDeviceAuth": true,
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "*"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "2dfe66ad1abc81d0d88a147de977484c"
    }
  },
  "logging": {
    "level": "info"
  },
  "env": {
    "MINIMAX_API_KEY": "test-key-12345678"
  },
  "plugins": {
    "allow": [
      "feishu"
    ],
    "load": {
      "paths": [
        "/app/extensions",
        "/root/.openclaw/extensions"
      ]
    }
  }
}